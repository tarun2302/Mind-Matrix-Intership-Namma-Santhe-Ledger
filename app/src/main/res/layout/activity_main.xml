<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A237E"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/shopNameHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Namma Santhe Ledger"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#90CAF9"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- SUMMARY SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/dailySummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:text="Daily Summary: &quot;Today you sold for ₹0; Dues pending ₹0.&quot;"
            android:textColor="#1A237E"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="14dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL OUTSTANDING"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/totalOutstanding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#E53935"
                android:textSize="32sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ADD TRANSACTION FORM -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/card_background"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="➕ Add Transaction (2-Step)"
            android:textColor="#1A237E"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <AutoCompleteTextView
            android:id="@+id/customerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1. Select/Enter Customer Name"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:padding="10dp"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="2. Amount ₹ (Large Keypad)"
            android:inputType="numberDecimal"
            android:background="@drawable/input_background"
            android:padding="12dp"
            android:textSize="20sp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/addUdariButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Add Udari"
                android:backgroundTint="#E53935"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/addPaymentButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Payment Log"
                android:backgroundTint="#2E7D32"
                android:textColor="#FFFFFF"
                android:layout_marginStart="4dp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/searchCustomer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:hint="🔍 Search Customer by Name..."
        android:inputType="text"
        android:background="@drawable/input_background"
        android:padding="10dp"
        android:textSize="14sp"/>

    <!-- HISTORY HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Recent Transactions"
            android:textColor="#212121"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/clearAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear All"
            android:textColor="#E53935"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="4dp"/>
    </LinearLayout>

    <!-- TRANSACTION LIST -->
    <ListView
        android:id="@+id/historyList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/card_background"
        android:divider="#F0F2F5"
        android:dividerHeight="1dp"/>

</LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addCustomerFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#1A237E"
        app:tint="#FFFFFF"
        android:contentDescription="Add Customer"/>

</RelativeLayout>